{
  "name": "premium-resume-studio",
  "version": "2.0.0",
  "description": "Autonomous premium-resume builder for anyone who wants a professional-yet-creative resume that stands out: auto-classifies the archetype, researches the person, renders a CEO-grade PDF (HTML+CSS+Chromium), and iterates with a model council until the score clears 85.",
  "main": "scripts/build_resume.js",
  "bin": {
    "premium-resume": "scripts/build_resume.js",
    "resume-council": "scripts/lib/council.js"
  },
  "scripts": {
    "build": "node scripts/build_resume.js --profile profile/sourabh.json --out output.pdf --html",
    "build:full": "node scripts/build_resume.js --profile profile/sourabh.json --out output.pdf --html --all",
    "score": "node scripts/lib/council.js --profile profile/sourabh.json",
    "themes": "node scripts/build_resume.js --list-themes",
    "templates": "node scripts/build_resume.js --list-templates"
  },
  "keywords": [
    "resume",
    "cv",
    "pdf",
    "playwright",
    "chromium",
    "agent-skill",
    "claude",
    "gemini",
    "ats",
    "resume-scoring",
    "resume-builder",
    "cover-letter"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "jszip": "^3.10.1",
    "playwright": "^1.60.0"
  }
}
